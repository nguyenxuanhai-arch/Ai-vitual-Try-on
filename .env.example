# --- Cấu hình Gemini AI ---
# NEXT_PUBLIC_GEMINI_API_KEY: Khóa API cho các dịch vụ Gemini.
# Nếu bạn deploy lên AI Studio, khóa này sẽ được tự động tiêm vào.
# Nếu deploy lên môi trường khác (Vercel, Netlify, Docker), hãy thiết lập biến này.
NEXT_PUBLIC_GEMINI_API_KEY=

# --- Cấu hình Ứng dụng ---
# APP_URL: URL của ứng dụng (dùng cho các liên kết tự tham chiếu).
APP_URL=

# NODE_ENV: Môi trường chạy (development, production).
NODE_ENV=production
